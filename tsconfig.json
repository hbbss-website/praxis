{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "types": ["node", "bun-types"]
  },
  "include": [
    "backend/src/**/*.ts",
    "backend/src/**/*.d.ts",
    "backend/tests/**/*.ts",
    "frontend/ts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["frontend/js", "node_modules"]
}
