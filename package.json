{
  "name": "social-practice-system",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:frontend": "vite",
    "dev": "concurrently -n \"API,WEB\" -c \"magenta,cyan\" \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "build": "vite build",
    "start": "pnpm build && tsx backend/src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --ui",
    "test:all": "pnpm typecheck && pnpm test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx backend/scripts/migrate.ts",
    "db:migrate:name-initials": "tsx backend/scripts/migrate-name-initials.ts",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-table": "^8.21.3",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "drizzle-orm": "1.0.0-beta.21",
    "fast-csv": "^5.0.7",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "lucide-react": "^0.577.0",
    "pinyin-pro": "^3.28.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sharp": "^0.34.5",
    "smol-toml": "^1.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/busboy": "^1.5.4",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "3.2.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "1.0.0-beta.21",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.4"
  }
}
