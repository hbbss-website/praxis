{
  "name": "hzw-website",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun build:frontend && concurrently -n \"API,AUTOBUILD\" -c \"magenta,cyan\" \"bun --hot backend/src/server.ts\" \"bun --hot frontend/autobuild.ts\"",
    "start": "bun build:frontend && bun backend/src/server.ts",
    "build:frontend": "bun frontend/build.ts",
    "typecheck": "tsc --noEmit",
    "test:all": "bun build:frontend && bun typecheck && bun test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}