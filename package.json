{
  "name": "hzw-website",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun --hot backend/src/server.ts",
    "start": "bun run build:frontend && bun backend/src/server.ts",
    "build:frontend": "bun build frontend/ts/login.ts frontend/ts/student/dashboard.ts frontend/ts/student/upload.ts frontend/ts/teacher/dashboard.ts --root frontend/ts --outdir frontend/js --target browser --format esm",
    "typecheck": "tsc --noEmit",
    "test": "bun run build:frontend && bun run typecheck && bun test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
